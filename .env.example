# 환경변수 템플릿 (Vite)
# 이 파일을 복사해서 .env.local 을 만들고 실제 값을 채워주세요.
#   cp .env.example .env.local
#
# 규칙:
# - 브라우저(클라이언트)에 노출되는 변수는 반드시 VITE_ 접두사를 붙입니다.
# - 코드에서는 import.meta.env.VITE_XXX 로 접근합니다.
# - 비밀키(시크릿)는 VITE_ 접두사를 붙이지 마세요. 번들에 그대로 노출됩니다.

# 앱 메타
VITE_APP_TITLE=Vibe Design Starter Kit
VITE_APP_ENV=development

# API 엔드포인트
VITE_API_BASE_URL=http://localhost:3000

# Gemini API (Node 이미지 생성 스크립트 전용)
# 키 발급: https://aistudio.google.com/app/apikey
# VITE_ 접두사 없음 → 브라우저에 노출되지 않음. 스크립트에서 process.env.GEMINI_API_KEY 로 읽습니다.
GEMINI_API_KEY=
